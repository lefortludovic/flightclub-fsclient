<Window x:Class="FlightClub.FsClient.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FlightClub.FsClient.ViewModels"
        xmlns:helpers="clr-namespace:FlightClub.FsClient.Helpers"
        Title="FlightClub - Flight Simulator Client"
        Width="480" SizeToContent="Height"
        MinHeight="300" MaxHeight="780"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#1E1E2E">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <helpers:BooleanToColorConverter x:Key="BoolToColor" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Card style -->
        <Style x:Key="StatusCard" TargetType="Border">
            <Setter Property="Background" Value="#313244" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,4" />
        </Style>

        <!-- Card title -->
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Card detail -->
        <Style x:Key="CardDetail" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A6ADC8" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <!-- Icon circle -->
        <Style x:Key="IconCircle" TargetType="Border">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="CornerRadius" Value="19" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>

        <!-- Icon text -->
        <Style x:Key="IconText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Data label -->
        <Style x:Key="DataLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A6ADC8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,3" />
        </Style>

        <!-- Data value -->
        <Style x:Key="DataValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A6E3A1" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,3" />
        </Style>

    </Window.Resources>

    <StackPanel Margin="24,20,24,24">

            <!-- Header -->
            <TextBlock Text="FlightClub"
                       FontSize="26" FontWeight="Bold"
                       Foreground="#CBA6F7"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Flight Simulator Client"
                       FontSize="13" Foreground="#A6ADC8"
                       HorizontalAlignment="Center"
                       Margin="0,2,0,20" />

            <!-- MSFS Status Card -->
            <Border Style="{StaticResource StatusCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource IconCircle}" Background="#45475A">
                        <TextBlock Text="&#x2708;" Style="{StaticResource IconText}" Foreground="#89B4FA" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="MSFS" Style="{StaticResource CardTitle}" />
                        <TextBlock Text="{Binding SimStatus}" Style="{StaticResource CardDetail}" />
                    </StackPanel>

                    <Ellipse Grid.Column="2" Width="12" Height="12" VerticalAlignment="Center"
                             Fill="{Binding IsSimConnected, Converter={StaticResource BoolToColor}}" />
                </Grid>
            </Border>

            <!-- Server Status Card -->
            <Border Style="{StaticResource StatusCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource IconCircle}" Background="#45475A">
                        <TextBlock Text="&#x2601;" Style="{StaticResource IconText}" Foreground="#F9E2AF" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="FlightClub.be server" Style="{StaticResource CardTitle}" />
                        <TextBlock Text="{Binding HubStatus}" Style="{StaticResource CardDetail}" />
                    </StackPanel>

                    <Ellipse Grid.Column="2" Width="12" Height="12" VerticalAlignment="Center"
                             Fill="{Binding IsHubConnected, Converter={StaticResource BoolToColor}}" />
                </Grid>
            </Border>

            <!-- Pairing Status Card -->
            <Border Style="{StaticResource StatusCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource IconCircle}" Background="#45475A">
                        <TextBlock Text="&#x1F464;" Style="{StaticResource IconText}" Foreground="#A6E3A1" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Pairing" Style="{StaticResource CardTitle}" />
                        <TextBlock Text="{Binding PairingStatus}" Style="{StaticResource CardDetail}" />
                    </StackPanel>

                    <Ellipse Grid.Column="2" Width="12" Height="12" VerticalAlignment="Center"
                             Fill="{Binding IsPaired, Converter={StaticResource BoolToColor}}" />
                </Grid>
            </Border>

            <!-- QR Code Section -->
            <Border HorizontalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource StatusCard}">
                        <Setter Property="Margin" Value="0,12" />
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding QrCodeImage, Converter={x:Static helpers:NullToBoolConverter.Instance}}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Scan to pair" FontSize="12" Foreground="#A6ADC8"
                               HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <Image Source="{Binding QrCodeImage}"
                           Width="160" Height="160"
                           RenderOptions.BitmapScalingMode="NearestNeighbor" />
                    <TextBlock FontSize="11" Foreground="#6C7086"
                               HorizontalAlignment="Center" Margin="0,8,0,0"
                               Text="Or enter session ID manually:" />
                    <TextBlock FontSize="13" Foreground="#CDD6F4" FontFamily="Consolas"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,4,0,0"
                               Text="{Binding SessionId}"
                               Cursor="Hand" ToolTip="Click to copy"
                               MouseLeftButtonUp="SessionId_Click" />
                </StackPanel>
            </Border>

            <!-- Aircraft Data -->
            <Border Style="{StaticResource StatusCard}" Margin="0,4,0,0"
                    Visibility="{Binding HasAircraftData, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Aircraft Data" Style="{StaticResource CardTitle}" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Latitude" Style="{StaticResource DataLabel}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Latitude, StringFormat=F6}" Style="{StaticResource DataValue}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Longitude" Style="{StaticResource DataLabel}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Longitude, StringFormat=F6}" Style="{StaticResource DataValue}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Altitude" Style="{StaticResource DataLabel}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource DataValue}">
                            <Run Text="{Binding Altitude, StringFormat=F0}" /><Run Text=" ft" Foreground="#6C7086" />
                        </TextBlock>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Ground Speed" Style="{StaticResource DataLabel}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource DataValue}">
                            <Run Text="{Binding GroundSpeed, StringFormat=F0}" /><Run Text=" kts" Foreground="#6C7086" />
                        </TextBlock>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Heading" Style="{StaticResource DataLabel}" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource DataValue}">
                            <Run Text="{Binding Heading, StringFormat=F0}" /><Run Text="&#x00B0;" Foreground="#6C7086" />
                        </TextBlock>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="On Ground" Style="{StaticResource DataLabel}" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding OnGround}" Style="{StaticResource DataValue}" />
                    </Grid>
                </StackPanel>
            </Border>

    </StackPanel>
</Window>
